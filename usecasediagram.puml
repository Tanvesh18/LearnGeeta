@startuml LearnGeetaUseCaseSimple
title Use Case Diagram of LearnGeeta Application

left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam packageStyle rectangle

actor User

rectangle "LearnGeeta Mobile Application" {

  usecase "Register / Login" as UC1
  usecase "Learn Bhagavad Gita" as UC2
  usecase "Play Gamified Learning Games" as UC3
  usecase "Track Progress & Achievements" as UC4
  usecase "Manage Profile" as UC5
  usecase "Access Daily Shloka" as UC6
  usecase "Logout" as UC7
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7

UC3 --> UC4 : <<include>>

@enduml