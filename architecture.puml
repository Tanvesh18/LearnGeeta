@startuml LearnGeetaArchitectureSimple
title System Architecture of LearnGeeta Application

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam linetype ortho

skinparam rectangle {
  RoundCorner 10
  BorderColor #333333
}

actor User

package "Presentation Layer" #E8F4F8 {
  rectangle "Flutter Mobile App\n(Android / iOS)" as App
  rectangle "Modules:\nHome | Learn | Games | Progress | Profile" as UI
}

package "Application Layer" #F3E8FF {
  rectangle "State Management\n(Provider)" as State
  rectangle "Business Logic\nXP | Levels | Game Engine" as Logic
  rectangle "Repositories / Services" as Repo
}

package "Storage Layer" #E8F8E8 {
  rectangle "SharedPreferences\n(Local Cache)" as Local
}

package "Backend Layer" #FFF4E6 {
  rectangle "Supabase Backend\nAuth + REST API" as Supabase
  database "PostgreSQL Database" as DB
}

User --> App
App --> UI
UI --> State
State --> Logic
Logic --> Repo
Repo --> Supabase
Supabase --> DB
Repo --> Local

@enduml