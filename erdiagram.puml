@startuml LearnGeetaERDiagramSimple
title Entity Relationship Diagram of LearnGeeta Database

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam linetype ortho

entity "users" as users {
  * id <<PK>>
  --
  email
}

entity "profiles" as profiles {
  * id <<PK>>
  --
  user_id <<FK>>
  username
  level
  xp
}

entity "progress" as progress {
  * id <<PK>>
  --
  user_id <<FK>>
  streak
}

entity "game_stats" as game_stats {
  * id <<PK>>
  --
  user_id <<FK>>
  game_name
  high_score
}

entity "achievements" as achievements {
  * id <<PK>>
  --
  user_id <<FK>>
  badge_name
}

users ||--|| profiles : owns
users ||--|| progress : tracks
users ||--o{ game_stats : records
users ||--o{ achievements : unlocks

@enduml