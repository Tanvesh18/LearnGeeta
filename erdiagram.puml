@startuml LearnGeetaERDiagram
title LearnGeeta Database ER Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Segoe UI
skinparam linetype ortho
skinparam class {
  BackgroundColor #FDFDFD
  BorderColor #333333
  ArrowColor #333333
}

entity "users" as users {
  * id : uuid <<PK>>
  --
  email : text
  created_at : timestamp
}

entity "profiles" as profiles {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  username : text
  level : int
  xp : int
  streak : int
  avatar_url : text
}

entity "progress" as progress {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  total_xp : int
  current_level : int
  last_active : date
  streak_count : int
}

entity "game_stats" as game_stats {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  game_name : text
  high_score : int
  total_games : int
  max_streak : int
  updated_at : timestamp
}

entity "achievements" as achievements {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  badge_name : text
  description : text
  unlocked_at : timestamp
}

users ||--|| profiles : owns
users ||--|| progress : tracks
users ||--o{ game_stats : has
users ||--o{ achievements : unlocks

@enduml